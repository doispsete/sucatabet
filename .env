# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SUCATABET - ARQUIVO DE EXEMPLO DE VARIÁVEIS DE AMBIENTE (.env)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copie este arquivo para .env e preencha os valores reais antes do deploy.
# IMPORTANTE: Nunca versione o arquivo .env real com valores sensíveis!

# ==============================================================================
# 🚀 CONFIGURAÇÕES DA API (BACKEND)
# ==============================================================================

# [OBRIGATÓRIO] URL de conexão com o banco de dados PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:2ebb55528d1d2d6d509dd9d12087818798d123f26a8d0a4e9d39b43494edaa8a@postgres:5432/sucatabet_db?schema=public"

# [OBRIGATÓRIO] Segredo para assinatura de Tokens JWT
# Requisito: Mínimo de 32 caracteres aleatórios. O app falhará no boot sem isso.
JWT_SECRET="4LduTIZ0tJEVTd+I9auHCvGKLN5At/4Y9iyLqBHAHrM="

# Tempo de expiração do Token JWT (ex: 1h, 8h, 7d)
JWT_EXPIRATION="8h"

# Tempo de expiração do Refresh Token (se aplicável)
JWT_REFRESH_EXPIRATION="7d"

# Porta onde a API irá rodar (Default: 3006)
PORT=3000

# Ambiente do sistema (development | production | test)
NODE_ENV="production"

# URL do Frontend para configuração de CORS (essencial em produção)
# Deve ser a URL exata onde o site estará hospedado (ex: https://sucatabet.com)
FRONTEND_URL="http://sucatabet.com.br"

# [OPCIONAL] Configurações de Rate Limiting (Throttler)
# TTL em segundos (v5+ por padrão usa s, não ms) e Limite de requisições por IP
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# [OPCIONAL] URL do Redis para cache (se utilizado em produção)
# REDIS_URL="redis://localhost:6379"


# ==============================================================================
# 🌐 CONFIGURAÇÕES DO WEB (FRONTEND)
# ==============================================================================

# [OBRIGATÓRIO] URL pública da API para o Next.js
# Deve ser acessível pelo navegador do usuário final.
NEXT_PUBLIC_API_URL="https://sucatabet.com.br/api"

# [OBRIGATÓRIO para NextAuth] Segredo para sessões do frontend
# Gere um segredo aleatório (ex: openssl rand -base64 32)
NEXTAUTH_SECRET="pu1bqjxiJjFaB4NhxR4d95/Wkyd1bF432DjqkeFtDAo="

# [OBRIGATÓRIO para NextAuth] URL base do site (ex: https://sucatabet.com)
NEXTAUTH_URL="http://sucatabet.com.br"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

POSTGRES_DB="sucatabet_db"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="2ebb55528d1d2d6d509dd9d12087818798d123f26a8d0a4e9d39b43494edaa8a"
