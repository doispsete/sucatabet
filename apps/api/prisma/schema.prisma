generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OPERATOR
}

enum AccountStatus {
  ACTIVE
  LIMITED
  CANCELLED
}

enum OperationType {
  NORMAL
  FREEBET_GEN
  EXTRACAO
  BOOST_25
  BOOST_30
  BOOST_50
  SUPERODDS
  TENTATIVA_DUPLO
}

enum OperationCategory {
  GERACAO
  CONVERSAO
  BOOST
  RISCO
}

enum OperationStatus {
  PENDING
  FINISHED
  CASHOUT
  VOID
}

enum OperationResult {
  NORMAL
  DUPLO
  PROTECAO
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
}

enum UserPlan {
  FREE
  BASIC
  PRO
}

model User {
  id          String       @id @default(uuid())
  email       String       @unique
  password    String       // hash
  name        String
  role        UserRole     @default(OPERATOR)
  status      UserStatus   @default(PENDING)
  plan        UserPlan     @default(FREE)
  approvedAt  DateTime?
  cpfProfiles CpfProfile[]
  operations  Operation[]
  logs        AuditLog[]
  freebets    Freebet[]
  bankAccount BankAccount?
}

model CpfProfile {
  id        String    @id @default(uuid())
  cpf       String    @unique // 6 primeiros dígitos para display
  name      String
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  accounts  Account[]
  deletedAt DateTime?

  @@index([deletedAt])
}

model BettingHouse {
  id        String    @id @default(uuid())
  name      String
  domain    String?
  logoUrl   String?   // gerado via favicon automático
  accounts  Account[]
}

model Account {
  id             String       @id @default(uuid())
  balance        Decimal      @default(0.0)
  inOperation    Decimal      @default(0.0)
  cpfProfileId   String
  cpfProfile     CpfProfile   @relation(fields: [cpfProfileId], references: [id])
  bettingHouseId String
  bettingHouse   BettingHouse @relation(fields: [bettingHouseId], references: [id])
  bets           Bet[]
  freebets       Freebet[]
  weeklyClubs    WeeklyClub[] 

  status         AccountStatus @default(ACTIVE)

  @@index([cpfProfileId])
  @@index([bettingHouseId])
  @@index([status])
  @@unique([cpfProfileId, bettingHouseId])
}

model Operation {
  id               String            @id @default(uuid())
  type             OperationType
  category         OperationCategory
  status           OperationStatus   @default(PENDING)
  result           OperationResult?
  expectedProfit   Decimal
  realProfit       Decimal?
  profitDifference Decimal?
  userId           String
  user             User              @relation(fields: [userId], references: [id])
  bets             Bet[]
  freebet          Freebet?
  description      String?
  generatedFbValue Decimal?
  createdAt        DateTime          @default(now())

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Bet {
  id             String    @id @default(uuid())
  odds           Decimal
  stake          Decimal
  cost           Decimal   @default(0.0)
  expectedProfit Decimal
  side           String    @default("BACK") // BACK ou LAY
  type           String    @default("Normal") // Normal, Freebet ou Aumento
  operationId    String
  operation      Operation @relation(fields: [operationId], references: [id])
  accountId      String
  account        Account   @relation(fields: [accountId], references: [id])
  isWinner       Boolean   @default(false)
  commission     Decimal   @default(0.0)
  isBenefit      Boolean   @default(false)

  @@index([operationId])
  @@index([accountId])
}

model Freebet {
  id        String    @id @default(uuid())
  value     Decimal
  origin    String
  expiresAt DateTime
  usedAt    DateTime? 
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  accountId String
  account   Account   @relation(fields: [accountId], references: [id])
  operationId String?   @unique
  operation   Operation? @relation(fields: [operationId], references: [id])
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String   // CREATE | UPDATE | DELETE | DEPOSIT | WITHDRAW | CLOSE | VOID | RESET
  entity     String
  entityId   String
  oldValue   Json?
  newValue   Json?
  executedBy String
  user       User     @relation(fields: [executedBy], references: [id])
  createdAt  DateTime @default(now())

  @@index([executedBy])
  @@index([createdAt])
}

model WeeklyClub {
  id         String   @id @default(uuid())
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id])
  weekStart  DateTime
  totalStake Decimal  @default(0.0)

  @@index([accountId])
  @@index([weekStart])
  @@unique([accountId, weekStart])
}

enum BankTransactionType {
  DEPOSIT
  WITHDRAW
  ACCOUNT_DEPOSIT
  ACCOUNT_WITHDRAW
  EXPENSE_PAYMENT
  INCOME
}

enum ExpenseType {
  OPERACIONAL
  PESSOAL
}

enum ExpenseStatus {
  PENDING
  PAID
  OVERDUE
}

model BankAccount {
  id           String            @id @default(uuid())
  userId       String            @unique
  user         User              @relation(fields: [userId], references: [id])
  balance      Decimal           @default(0)
  monthlyGoal  Decimal           @default(0)
  transactions BankTransaction[]
  expenses     Expense[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model BankTransaction {
  id            String              @id @default(uuid())
  bankAccountId String
  bankAccount   BankAccount         @relation(fields: [bankAccountId], references: [id])
  type          BankTransactionType
  amount        Decimal
  description   String
  referenceId   String?
  referenceType String?             // "account_deposit", "account_withdraw", "expense", "manual"
  createdAt     DateTime            @default(now())
}

model Expense {
  id                   String        @id @default(uuid())
  bankAccountId        String
  bankAccount          BankAccount   @relation(fields: [bankAccountId], references: [id])
  name                 String
  type                 ExpenseType
  amount               Decimal
  dueDay               Int
  recurring            Boolean       @default(true)
  totalOccurrences     Int?
  remainingOccurrences Int?
  lastPaidAt           DateTime?
  nextDueAt            DateTime
  status               ExpenseStatus @default(PENDING)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

