{
  "log-driver": "json-file",
  "log-opts": {
    "max-size": "10m",
    "max-file": "3"
  },
  "features": {
    "buildkit": true
  },
  "builder": {
    "gc": {
      "defaultKeepStorage": "20GB",
      "enabled": true,
      "policy": [
        { "keepStorage": "10GB", "filter": ["unused-for=48h"] },
        { "keepStorage": "20GB", "filter": ["unused-for=168h"] },
        { "keepStorage": "30GB" }
      ]
    }
  }
}
